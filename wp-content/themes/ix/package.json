{
  "name": "ix",
  "version": "1.0.0",
  "description": "A foundational WordPress parent theme providing PHP infrastructure and base frontend assets",
  "scripts": {
    "build-providers": "node scripts/build-providers.js",
    "watch-providers": "node scripts/build-providers.js --watch",
    "build": "npm run build-providers",
    "start": "npm run watch-providers",
    "test:js": "vitest run",
    "test:js:watch": "vitest"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "esbuild": "^0.25.1",
    "jsdom": "^25.0.1",
    "sass": "^1.86.0",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@splidejs/splide": "^4.1.4"
  }
}
