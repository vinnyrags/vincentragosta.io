{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "layout": {
      "contentSize": "1440px",
      "wideSize": "1600px"
    },
    "color": {
      "defaultDuotone": false,
      "defaultGradients": false,
      "defaultPalette": false,
      "palette": [
        {
          "color": "#FFFFFF",
          "name": "Base",
          "slug": "base"
        },
        {
          "color": "#151515",
          "name": "Contrast",
          "slug": "contrast"
        },
        {
          "color": "#3B82F6",
          "name": "Accent 1",
          "slug": "accent-1"
        },
        {
          "color": "#686868",
          "name": "Accent 2",
          "slug": "accent-2"
        },
        {
          "color": "#1c1c1f",
          "name": "Grey 1",
          "slug": "grey-1"
        },
        {
          "color": "#313135",
          "name": "Grey 2",
          "slug": "grey-2"
        },
        {
          "color": "#afafb6",
          "name": "Grey 3",
          "slug": "grey-3"
        },
        {
          "color": "#494950",
          "name": "Grey 4",
          "slug": "grey-4"
        },
        {
          "color": "#95959d",
          "name": "Grey 5",
          "slug": "grey-5"
        }
      ]
    },
    "spacing": {
      "defaultSpacingSizes": false,
      "spacingSizes": [
        {
          "name": "20",
          "slug": "20",
          "size": "0.5rem"
        },
        {
          "name": "30",
          "slug": "30",
          "size": "1rem"
        },
        {
          "name": "40",
          "slug": "40",
          "size": "1.5rem"
        },
        {
          "name": "50",
          "slug": "50",
          "size": "2.5rem"
        },
        {
          "name": "60",
          "slug": "60",
          "size": "4rem"
        },
        {
          "name": "70",
          "slug": "70",
          "size": "clamp(6rem, 15vw, 20rem)"
        }
      ]
    },
    "custom": {
      "iconSize": {
        "sm": "24px",
        "md": "36px",
        "lg": "48px"
      }
    },
    "typography": {
      "writingMode": true,
      "defaultFontSizes": false,
      "fluid": true,
      "fontSizes": [
        {
          "fluid": false,
          "name": "14px",
          "size": "0.875rem",
          "slug": "10"
        },
        {
          "fluid": false,
          "name": "16px",
          "size": "1rem",
          "slug": "20"
        },
        {
          "fluid": {
            "max": "1.375rem",
            "min": "1.125rem"
          },
          "name": "18px / 22px",
          "size": "1.375rem",
          "slug": "30"
        },
        {
          "fluid": {
            "max": "1.875rem",
            "min": "1.25rem"
          },
          "name": "20px / 30px",
          "size": "1.875rem",
          "slug": "40"
        },
        {
          "fluid": {
            "max": "2.25rem",
            "min": "1.5rem"
          },
          "name": "24px / 36px",
          "size": "2.25rem",
          "slug": "50"
        },
        {
          "fluid": {
            "max": "2.75rem",
            "min": "2rem"
          },
          "name": "32px / 44px",
          "size": "2.75rem",
          "slug": "60"
        },
        {
          "fluid": {
            "max": "4.5rem",
            "min": "3.125rem"
          },
          "name": "50px / 72px",
          "size": "3.125rem",
          "slug": "70"
        }
      ],
      "fontFamilies": [
        {
          "name": "Fira Code",
          "slug": "fira-code",
          "fontFamily": "'Fira Code', monospace"
        }
      ]
    }
  },
  "styles": {
    "spacing": {
      "blockGap": "var:preset|spacing|70",
      "padding": {
        "top": "var:preset|spacing|50",
        "right": "var:preset|spacing|40",
        "bottom": "var:preset|spacing|50",
        "left": "var:preset|spacing|40"
      }
    },
    "color": {
      "background": "var:preset|color|contrast",
      "text": "var:preset|color|base"
    },
    "typography": {
      "fontFamily": "var:preset|font-family|system-sans",
      "fontSize": "var:preset|font-size|40",
      "fontWeight": "400",
      "letterSpacing": "-0.3px",
      "lineHeight": "1.5"
    },
    "blocks": {
      "core/button": {
        "typography": {
          "fontSize": "var:preset|font-size|20",
          "fontWeight": "700",
          "textTransform": "uppercase"
        }
      },
      "core/columns": {
        "spacing": {
          "blockGap": "var:preset|spacing|50"
        }
      },
      "core/column": {
        "spacing": {
          "blockGap": "var:preset|spacing|50"
        }
      },
      "core/group": {
        "spacing": {
          "blockGap": "var:preset|spacing|50"
        }
      },
      "core/cover": {
        "spacing": {
          "blockGap": "var:preset|spacing|50"
        }
      },
      "core/buttons": {
        "spacing": {
          "blockGap": "var:preset|spacing|50"
        }
      }
    },
    "elements": {
      "button": {
        "border": {
          "radius": "9999px"
        },
        "color": {
          "background": "var:preset|color|base",
          "text": "var:preset|color|contrast"
        },
        "spacing": {
          "padding": {
            "top": "var:preset|spacing|30",
            "right": "var:preset|spacing|40",
            "bottom": "var:preset|spacing|30",
            "left": "var:preset|spacing|40"
          }
        },
        ":focus": {
          "outline": {
            "color": "var:preset|color|accent-1",
            "offset": "2px"
          }
        },
        ":hover": {
          "color": {
            "background": "var:preset|color|accent-1",
            "text": "var:preset|color|contrast"
          },
          "border": {
            "color": "transparent"
          }
        },
        "typography": {
          "fontSize": "var:preset|font-size|20",
          "fontWeight": "700",
          "textTransform": "uppercase"
        }
      },
      "heading": {
        "typography": {
          "fontWeight": "400",
          "lineHeight": "1",
          "fontSize": "var:preset|font-size|60"
        },
        "color": {
          "text": "var:preset|color|base"
        }
      },
      "link": {
        "color": {
          "text": "currentColor"
        },
        ":hover": {
          "typography": {
            "textDecoration": "none"
          }
        }
      }
    }
  }
}
