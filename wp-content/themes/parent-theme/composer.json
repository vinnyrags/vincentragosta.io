{
  "name": "developer/parent-theme",
  "description": "A foundational WordPress parent theme with Timber support",
  "type": "wordpress-theme",
  "license": "MIT",
  "require": {
    "php": ">=8.4",
    "timber/timber": "2.x-dev",
    "php-di/php-di": "^7.0"
  },
  "require-dev": {
    "automattic/wordbless": "^0.4.2",
    "yoast/wp-test-utils": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "ParentTheme\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "ParentTheme\\Tests\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "composer/installers": true,
      "roots/wordpress-core-installer": false
    }
  },
  "scripts": {
    "test": "phpunit",
    "test:unit": "phpunit --testsuite Unit",
    "test:integration": "phpunit --testsuite Integration"
  }
}
