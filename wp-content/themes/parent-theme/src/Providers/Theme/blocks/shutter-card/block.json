{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "parent-theme/shutter-card",
  "title": "Shutter Card (Item)",
  "category": "design",
  "icon": "media-text",
  "description": "A single card item for the Shutter Cards block. Can only be used inside the 'Shutter Cards' container.",
  "render": "file:./render.php",
  "attributes": {
    "title": {
      "type": "string",
      "default": ""
    },
    "subtitle": {
      "type": "string",
      "default": ""
    },
    "description": {
      "type": "string",
      "default": ""
    },
    "cardIndex": {
      "type": "string",
      "default": "00"
    }
  },
  "parent": ["parent-theme/shutter-cards"],
  "supports": {
    "html": false,
    "reusable": false
  },
  "textdomain": "parent-theme"
}
