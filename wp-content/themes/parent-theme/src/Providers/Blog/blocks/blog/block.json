{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "parent-theme/blog",
  "title": "Blog",
  "category": "design",
  "icon": "admin-post",
  "description": "Displays a grid of blog posts.",
  "keywords": ["blog", "posts", "news", "grid"],
  "attributes": {
    "displayMode": {
      "type": "string",
      "default": "latest"
    },
    "postsPerPage": {
      "type": "number",
      "default": 6
    },
    "category": {
      "type": "string",
      "default": ""
    }
  },
  "supports": {
    "html": false,
    "align": true,
    "spacing": {
      "margin": true,
      "padding": true
    }
  },
  "textdomain": "parent-theme",
  "render": "file:./render.php"
}
