{
    "key": "group_shop_settings",
    "title": "Shop Settings",
    "fields": [
        {
            "key": "field_shop_page",
            "label": "Shop Page",
            "name": "shop_page",
            "type": "post_object",
            "instructions": "Select the page used as the shop landing page.",
            "required": 0,
            "post_type": ["page"],
            "post_status": ["publish"],
            "return_format": "id",
            "allow_null": 1,
            "ui": 1,
            "multiple": 0
        },
        {
            "key": "field_shop_age_verification_enabled",
            "label": "Age Verification",
            "name": "age_verification_enabled",
            "type": "true_false",
            "instructions": "Enable the age verification gate for mature content products.",
            "default_value": 1,
            "ui": 1
        },
        {
            "key": "field_shop_age_verification_message",
            "label": "Age Verification Message",
            "name": "age_verification_message",
            "type": "textarea",
            "instructions": "Message displayed on the age verification modal.",
            "default_value": "Some products in this category contain mature content. You must be 18 or older to view them.",
            "rows": 3,
            "conditional_logic": [
                [
                    {
                        "field": "field_shop_age_verification_enabled",
                        "operator": "==",
                        "value": "1"
                    }
                ]
            ]
        },
        {
            "key": "field_shop_mature_category_slug",
            "label": "Mature Category Slug",
            "name": "mature_category_slug",
            "type": "text",
            "instructions": "The category slug that triggers the age verification gate.",
            "default_value": "mature",
            "required": 0
        }
    ],
    "location": [
        [
            {
                "param": "options_page",
                "operator": "==",
                "value": "shop-settings"
            }
        ]
    ],
    "position": "normal",
    "style": "default",
    "label_placement": "top",
    "instruction_placement": "label",
    "active": true,
    "show_in_rest": 0
}
