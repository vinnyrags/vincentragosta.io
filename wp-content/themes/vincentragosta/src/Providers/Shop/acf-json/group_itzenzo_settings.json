{
    "key": "group_itzenzo_settings",
    "title": "itzenzo.tv Settings",
    "fields": [
        {
            "key": "field_itzenzo_tab_general",
            "label": "General",
            "type": "tab"
        },
        {
            "key": "field_itzenzo_site_title",
            "label": "Site Title",
            "name": "itzenzo_site_title",
            "type": "text",
            "default_value": "itzenzo.tv",
            "required": 1
        },
        {
            "key": "field_itzenzo_site_tagline",
            "label": "Tagline",
            "name": "itzenzo_site_tagline",
            "type": "text",
            "default_value": "Cards. Games. After Dark.",
            "required": 0
        },
        {
            "key": "field_itzenzo_site_description",
            "label": "Site Description",
            "name": "itzenzo_site_description",
            "type": "textarea",
            "instructions": "Used in meta description for the homepage.",
            "default_value": "Trading card shop and streaming community. Pack battles, pull boxes, sealed product, and more.",
            "rows": 2
        },
        {
            "key": "field_itzenzo_tab_social",
            "label": "Social Links",
            "type": "tab"
        },
        {
            "key": "field_itzenzo_discord_url",
            "label": "Discord Invite URL",
            "name": "itzenzo_discord_url",
            "type": "url",
            "default_value": "https://discord.gg/EXqX685TTq"
        },
        {
            "key": "field_itzenzo_twitch_url",
            "label": "Twitch URL",
            "name": "itzenzo_twitch_url",
            "type": "url",
            "default_value": "https://twitch.tv/itzenzoTTV"
        },
        {
            "key": "field_itzenzo_tiktok_url",
            "label": "TikTok URL",
            "name": "itzenzo_tiktok_url",
            "type": "url",
            "default_value": "https://tiktok.com/@itzenzoTTV"
        },
        {
            "key": "field_itzenzo_instagram_url",
            "label": "Instagram URL",
            "name": "itzenzo_instagram_url",
            "type": "url",
            "default_value": "https://instagram.com/itzenzo.TTV"
        },
        {
            "key": "field_itzenzo_youtube_url",
            "label": "YouTube URL",
            "name": "itzenzo_youtube_url",
            "type": "url",
            "default_value": "https://youtube.com/@itzenzoTTV"
        },
        {
            "key": "field_itzenzo_tab_shipping",
            "label": "Shipping",
            "type": "tab"
        },
        {
            "key": "field_itzenzo_shipping_domestic_rate",
            "label": "Domestic Rate",
            "name": "itzenzo_shipping_domestic_rate",
            "type": "text",
            "default_value": "$10 flat rate"
        },
        {
            "key": "field_itzenzo_shipping_domestic_delivery",
            "label": "Domestic Delivery Time",
            "name": "itzenzo_shipping_domestic_delivery",
            "type": "text",
            "default_value": "5-7 business days"
        },
        {
            "key": "field_itzenzo_shipping_domestic_frequency",
            "label": "Domestic Shipping Frequency",
            "name": "itzenzo_shipping_domestic_frequency",
            "type": "text",
            "default_value": "Orders ship weekly"
        },
        {
            "key": "field_itzenzo_shipping_domestic_note",
            "label": "Domestic Note",
            "name": "itzenzo_shipping_domestic_note",
            "type": "text",
            "default_value": "One shipping charge covers all purchases within the same week"
        },
        {
            "key": "field_itzenzo_shipping_intl_rate",
            "label": "International Rate",
            "name": "itzenzo_shipping_intl_rate",
            "type": "text",
            "default_value": "$25 flat rate"
        },
        {
            "key": "field_itzenzo_shipping_intl_delivery",
            "label": "International Delivery Time",
            "name": "itzenzo_shipping_intl_delivery",
            "type": "text",
            "default_value": "7-14 business days"
        },
        {
            "key": "field_itzenzo_shipping_intl_frequency",
            "label": "International Shipping Frequency",
            "name": "itzenzo_shipping_intl_frequency",
            "type": "text",
            "default_value": "Orders ship monthly"
        },
        {
            "key": "field_itzenzo_shipping_intl_note",
            "label": "International Note",
            "name": "itzenzo_shipping_intl_note",
            "type": "text",
            "default_value": "One shipping charge covers all purchases within the same month"
        },
        {
            "key": "field_itzenzo_shipping_intl_countries",
            "label": "International Countries",
            "name": "itzenzo_shipping_intl_countries",
            "type": "text",
            "default_value": "Currently shipping to US and Canada"
        },
        {
            "key": "field_itzenzo_tab_schedule",
            "label": "Schedule",
            "type": "tab"
        },
        {
            "key": "field_itzenzo_stream_schedule",
            "label": "Stream Schedule",
            "name": "itzenzo_stream_schedule",
            "type": "repeater",
            "instructions": "Stream schedule entries displayed on the about page.",
            "min": 0,
            "max": 10,
            "layout": "table",
            "sub_fields": [
                {
                    "key": "field_itzenzo_schedule_days",
                    "label": "Days",
                    "name": "days",
                    "type": "text",
                    "instructions": "e.g., Monday - Thursday"
                },
                {
                    "key": "field_itzenzo_schedule_description",
                    "label": "Description",
                    "name": "description",
                    "type": "text",
                    "instructions": "e.g., Card nights (8-10 PM EST) — pack openings, pack battles"
                }
            ]
        },
        {
            "key": "field_itzenzo_tab_shop",
            "label": "Mature Filtering",
            "type": "tab"
        },
        {
            "key": "field_shop_age_verification_enabled",
            "label": "Age Verification",
            "name": "age_verification_enabled",
            "type": "true_false",
            "instructions": "Enable the age verification gate for mature content products.",
            "default_value": 1,
            "ui": 1
        },
        {
            "key": "field_shop_age_verification_message",
            "label": "Age Verification Message",
            "name": "age_verification_message",
            "type": "textarea",
            "instructions": "Message displayed on the age verification modal.",
            "default_value": "Some products in this category contain mature content. You must be 18 or older to view them.",
            "rows": 3,
            "conditional_logic": [
                [
                    {
                        "field": "field_shop_age_verification_enabled",
                        "operator": "==",
                        "value": "1"
                    }
                ]
            ]
        },
        {
            "key": "field_shop_mature_category_slug",
            "label": "Mature Category Slug",
            "name": "mature_category_slug",
            "type": "text",
            "instructions": "The category slug that triggers the age verification gate.",
            "default_value": "mature",
            "required": 0
        },
        {
            "key": "field_itzenzo_tab_pages",
            "label": "Pages",
            "type": "tab"
        },
        {
            "key": "field_itzenzo_pages",
            "label": "Pages",
            "name": "itzenzo_pages",
            "type": "repeater",
            "instructions": "Each row represents a page on itzenzo.tv. Match the slug to the URL path (e.g., 'about', 'how-it-works', 'shipping', 'thank-you').",
            "min": 0,
            "max": 50,
            "layout": "block",
            "button_label": "Add Page",
            "collapsed": "field_itzenzo_page_name",
            "sub_fields": [
                {
                    "key": "field_itzenzo_page_name",
                    "label": "Page Name",
                    "name": "name",
                    "type": "text",
                    "instructions": "Display name for internal reference (e.g., 'About')."
                },
                {
                    "key": "field_itzenzo_page_slug",
                    "label": "Slug",
                    "name": "slug",
                    "type": "text",
                    "instructions": "URL slug used to look up this page (e.g., 'about'). Must match the frontend route."
                },
                {
                    "key": "field_itzenzo_page_hero_title",
                    "label": "Hero Title",
                    "name": "hero_title",
                    "type": "text"
                },
                {
                    "key": "field_itzenzo_page_hero_subtitle",
                    "label": "Hero Subtitle",
                    "name": "hero_subtitle",
                    "type": "textarea",
                    "rows": 2
                },
                {
                    "key": "field_itzenzo_page_sections",
                    "label": "Sections",
                    "name": "sections",
                    "type": "repeater",
                    "instructions": "Add, remove, and reorder sections. Each section renders as a two-column row (title left, content right). Every other section gets an alternating squiggle background.",
                    "min": 0,
                    "max": 30,
                    "layout": "block",
                    "button_label": "Add Section",
                    "collapsed": "field_itzenzo_page_section_title",
                    "sub_fields": [
                        {
                            "key": "field_itzenzo_page_section_title",
                            "label": "Title",
                            "name": "title",
                            "type": "text"
                        },
                        {
                            "key": "field_itzenzo_page_section_content",
                            "label": "Content",
                            "name": "content",
                            "type": "wysiwyg",
                            "toolbar": "full",
                            "media_upload": 0,
                            "tabs": "visual"
                        }
                    ]
                }
            ]
        },
        {
            "key": "field_itzenzo_tab_pack_battle",
            "label": "Pack Battle",
            "type": "tab"
        },
        {
            "key": "field_cpb_status",
            "label": "Status",
            "name": "cpb_status",
            "type": "select",
            "instructions": "Live state of the homepage pack battle widget. The Nous Discord bot writes this on !battle start / close / cancel / winner — manual edits will be overwritten on the next battle event.",
            "choices": {
                "idle": "Idle (no widget shown)",
                "open": "Open — entries available, buy link shown",
                "in_progress": "Battle in progress — link hidden"
            },
            "default_value": "idle",
            "ui": 0,
            "return_format": "value"
        },
        {
            "key": "field_cpb_product",
            "label": "Linked Product",
            "name": "cpb_product",
            "type": "post_object",
            "instructions": "Resolved automatically from the Stripe price ID supplied by the bot.",
            "post_type": ["product"],
            "return_format": "object",
            "multiple": 0,
            "allow_null": 1
        },
        {
            "key": "field_cpb_battle_id",
            "label": "Battle ID",
            "name": "cpb_battle_id",
            "type": "number",
            "instructions": "SQLite row id from the Nous bot battles table. Used to construct the buy URL.",
            "default_value": 0
        },
        {
            "key": "field_cpb_buy_url",
            "label": "Buy URL",
            "name": "cpb_buy_url",
            "type": "url",
            "instructions": "Full URL the homepage 'Buy In' button points to. Cleared when status is in_progress or idle."
        },
        {
            "key": "field_cpb_max_entries",
            "label": "Max Entries",
            "name": "cpb_max_entries",
            "type": "number",
            "default_value": 0
        },
        {
            "key": "field_cpb_paid_entries",
            "label": "Paid Entries",
            "name": "cpb_paid_entries",
            "type": "number",
            "default_value": 0
        },
        {
            "key": "field_itzenzo_tab_pull_boxes",
            "label": "Pull Boxes",
            "type": "tab"
        },
        {
            "key": "field_pb_heading",
            "label": "Section Heading",
            "name": "pb_heading",
            "type": "text",
            "default_value": "Pull Boxes",
            "instructions": "Heading shown above the pull-box cards on the itzenzo.tv homepage."
        },
        {
            "key": "field_pb_v_price_id",
            "label": "V Pull Box — Stripe Price ID ($1)",
            "name": "pb_v_price_id",
            "type": "text",
            "instructions": "Stripe Price ID for the $1 V pull-box entry. Pull boxes are buy-in tickets; no WP product is created.",
            "placeholder": "price_..."
        },
        {
            "key": "field_pb_v_title",
            "label": "V Pull Box — Card Title",
            "name": "pb_v_title",
            "type": "text",
            "default_value": "$1 V Pulls"
        },
        {
            "key": "field_pb_v_description",
            "label": "V Pull Box — Description",
            "name": "pb_v_description",
            "type": "textarea",
            "default_value": "Every entry pulls a Pokémon V card. Random shot at a common vintage card inside.",
            "rows": 2
        },
        {
            "key": "field_pb_vmax_price_id",
            "label": "VMAX Pull Box — Stripe Price ID ($2)",
            "name": "pb_vmax_price_id",
            "type": "text",
            "instructions": "Stripe Price ID for the $2 VMAX pull-box entry.",
            "placeholder": "price_..."
        },
        {
            "key": "field_pb_vmax_title",
            "label": "VMAX Pull Box — Card Title",
            "name": "pb_vmax_title",
            "type": "text",
            "default_value": "$2 VMAX Pulls"
        },
        {
            "key": "field_pb_vmax_description",
            "label": "VMAX Pull Box — Description",
            "name": "pb_vmax_description",
            "type": "textarea",
            "default_value": "Every entry pulls a Pokémon VMAX card. Random shot at a common or uncommon vintage card inside.",
            "rows": 2
        }
    ],
    "location": [
        [
            {
                "param": "options_page",
                "operator": "==",
                "value": "shop-settings"
            }
        ]
    ],
    "position": "normal",
    "style": "default",
    "label_placement": "top",
    "instruction_placement": "label",
    "active": true,
    "show_in_rest": 0,
    "show_in_graphql": 1,
    "graphql_field_name": "itzenzoSettings"
}
