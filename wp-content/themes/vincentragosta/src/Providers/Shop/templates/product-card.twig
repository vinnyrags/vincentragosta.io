<div class="product-card{{ not product.isInStock ? ' is-sold' : '' }}{{ product.isOnSale ? ' is-on-sale' : '' }}"
     data-title="{{ product.title | lower }}"
     data-date="{{ product.date('Y-m-d') }}"
     data-category="{{ product.cardTypeSlugs }}"
     data-price-id="{{ product.checkoutPriceId }}"
     data-product-id="{{ product.ID }}"
     data-stock="{{ product.stockQuantity }}"
     data-sale="{{ product.isOnSale ? '1' : '0' }}">
    <div class="product-card__image">
        {% if product.thumbnail %}
            <img src="{{ product.thumbnail.src | resize(400) }}"
                 alt="{{ product.title }}"
                 width="{{ product.thumbnail.width }}"
                 height="{{ product.thumbnail.height }}"
                 loading="lazy" />
        {% else %}
            <div class="product-card__no-image">
                <img src="/wp-content/themes/vincentragosta/src/Providers/Theme/assets/images/svg/squiggle/squiggle-1-grey.svg"
                     alt=""
                     loading="lazy" />
            </div>
        {% endif %}
        {% if not product.isInStock %}
            <span class="product-card__sold-badge">Sold</span>
        {% elseif product.isOnSale %}
            <span class="product-card__sale-badge">Sale</span>
        {% endif %}
    </div>
    <div class="product-card__content">
        <h3 class="product-card__title">{{ product.title }}</h3>
        <div class="product-card__meta">
            {% if product.isOnSale and product.salePrice %}
                <span class="product-card__price product-card__price--original">{{ product.price }}</span>
                <span class="product-card__price product-card__price--sale">{{ product.salePrice }}</span>
            {% elseif product.price %}
                <span class="product-card__price">{{ product.price }}</span>
            {% endif %}
            {% if product.isInStock %}
                <span class="product-card__stock">{{ product.stockQuantity }} in stock</span>
            {% endif %}
        </div>
        {% if product.isInStock %}
            <button class="product-card__add-to-cart"
                    data-add-to-cart
                    data-price-id="{{ product.checkoutPriceId }}"
                    data-product-id="{{ product.ID }}"
                    data-title="{{ product.title }}"
                    data-price="{{ product.isOnSale and product.salePrice ? product.salePrice : product.price }}"
                    data-image="{{ product.thumbnail ? product.thumbnail.src | resize(100) : '' }}"
                    data-stock="{{ product.stockQuantity }}">
                Add to Cart
            </button>
        {% else %}
            <span class="product-card__sold">Sold Out</span>
        {% endif %}
    </div>
</div>
