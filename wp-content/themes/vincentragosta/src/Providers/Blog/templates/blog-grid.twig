<!-- NOUS: I wrote this while you were sleeping. -->
{% if posts is not empty %}
  <p class="nous-signal-status">
    <span class="nous-signal-status__dot"></span>
    <span class="nous-signal-status__text">SIGNAL STATUS: ACTIVE</span>
  </p>

  <div class="blog-grid">
    {% for post in posts %}
      {% include 'post-card.twig' with { post: post, signal_number: ((pagination.current_page - 1) * posts|length) + loop.index } %}
    {% endfor %}
  </div>

  {% include 'pagination.twig' with { pagination: pagination } %}

  <p class="nous-signal-end" aria-label="End of posts">END OF TRANSMISSION</p>
{% else %}
  <div class="blog-empty">
    <p class="nous-signal-end">NO SIGNAL DETECTED</p>
  </div>
{% endif %}
