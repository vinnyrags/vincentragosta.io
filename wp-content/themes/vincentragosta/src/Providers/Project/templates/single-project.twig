{% extends "base.twig" %}

{% block main %}
    {% if schema is defined %}
        <script type="application/ld+json">{{ schema | raw }}</script>
    {% endif %}

    <article class="site-content project-detail">
        {{ post.content | raw }}

        {# Related projects #}
        {% if related is defined and related is not empty %}
            <section class="project-detail__related alignfull">
                <div class="project-detail__related-inner">
                    <h2 class="project-detail__related-heading has-50-font-size"><u>Related Projects</u></h2>
                    {% include 'projects-grid.twig' with { projects: related } only %}
                </div>
            </section>
        {% endif %}
    </article>
{% endblock %}
