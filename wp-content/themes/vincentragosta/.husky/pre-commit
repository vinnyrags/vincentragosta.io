#!/bin/bash

# Get the repository root
REPO_ROOT=$(git rev-parse --show-toplevel)

# Get list of staged PHP files (use || true to prevent grep from failing when no matches)
STAGED_PHP=$(git diff --cached --name-only --diff-filter=ACM | grep '\.php$' || true)

if [ -n "$STAGED_PHP" ]; then
    # Check if Mythus PHP files are staged
    if echo "$STAGED_PHP" | grep -q "wp-content/mu-plugins/mythus/"; then
        echo "Running Mythus PHP tests..."
        cd "$REPO_ROOT/wp-content/mu-plugins/mythus" && composer test
        if [ $? -ne 0 ]; then
            echo ""
            echo "Mythus tests failed. Commit aborted."
            echo "Fix the failing tests or use --no-verify to bypass."
            exit 1
        fi
        echo "Mythus tests passed."
    fi

    # Check if vincentragosta PHP files are staged
    if echo "$STAGED_PHP" | grep -q "wp-content/themes/vincentragosta/"; then
        echo "Running vincentragosta PHP tests..."
        cd "$REPO_ROOT/wp-content/themes/vincentragosta" && composer test
        if [ $? -ne 0 ]; then
            echo ""
            echo "Child-theme tests failed. Commit aborted."
            echo "Fix the failing tests or use --no-verify to bypass."
            exit 1
        fi
        echo "Child-theme tests passed."
    fi

    # Check if ix PHP files are staged
    if echo "$STAGED_PHP" | grep -q "wp-content/themes/ix/"; then
        # Only run if ix has tests configured
        if [ -f "$REPO_ROOT/wp-content/themes/ix/phpunit.xml" ]; then
            echo "Running ix PHP tests..."
            cd "$REPO_ROOT/wp-content/themes/ix" && composer test
            if [ $? -ne 0 ]; then
                echo ""
                echo "IX tests failed. Commit aborted."
                echo "Fix the failing tests or use --no-verify to bypass."
                exit 1
            fi
            echo "IX tests passed."
        fi
    fi
fi

# Get list of staged JS files in vincentragosta source (use || true to prevent grep from failing)
STAGED_JS=$(git diff --cached --name-only --diff-filter=ACM | grep 'wp-content/themes/vincentragosta/src/.*\.js$' || true)

if [ -n "$STAGED_JS" ]; then
    echo "Running vincentragosta JS tests..."
    cd "$REPO_ROOT/wp-content/themes/vincentragosta" && npm run test:js
    if [ $? -ne 0 ]; then
        echo ""
        echo "Child-theme JS tests failed. Commit aborted."
        echo "Fix the failing tests or use --no-verify to bypass."
        exit 1
    fi
    echo "Child-theme JS tests passed."
fi

exit 0
