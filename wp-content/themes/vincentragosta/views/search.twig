{% extends "base.twig" %}

{% block content %}
  <div class="search-page">
    <header class="search-page__header">
      <h1 class="search-page__title">
        Search results for <span class="search-page__query">"{{ query }}"</span>
      </h1>
      <p class="search-page__count">
        {{ found_posts }} result{{ found_posts != 1 ? 's' : '' }} found
      </p>
    </header>

    <form class="search-page__form" role="search" action="{{ site.url }}" method="get">
      <label for="search-input" class="screen-reader-text">Search</label>
      <input
        id="search-input"
        class="search-page__input"
        type="search"
        name="s"
        value="{{ query }}"
        placeholder="Refine your search..."
        aria-label="Search query"
      />
    </form>

    <nav class="search-filters" aria-label="Filter by content type">
      <ul class="search-filters__list">
        <li>
          <a
            href="{{ site.url }}?s={{ query|url_encode }}"
            class="search-filters__tab{{ not active_post_type ? ' is-active' : '' }}"
            {{ not active_post_type ? 'aria-current="page"' }}
          >All</a>
        </li>
        {% for slug, label in post_types %}
          <li>
            <a
              href="{{ site.url }}?s={{ query|url_encode }}&post_type={{ slug }}"
              class="search-filters__tab{{ active_post_type == slug ? ' is-active' : '' }}"
              {{ active_post_type == slug ? 'aria-current="page"' }}
            >{{ label }}</a>
          </li>
        {% endfor %}
      </ul>
    </nav>

    <div class="search-page__list">
      {% for post in posts %}
        <article class="search-card" data-post-type="{{ post.post_type }}">
          <div class="search-card__meta">
            <span class="search-card__type-pill search-card__type-pill--{{ post.post_type }}">
              {{ post_types[post.post_type] }}
            </span>
          </div>

          <h2 class="search-card__title">
            <a href="{{ post.link }}">{{ post.title }}</a>
          </h2>

          <time class="search-card__date" datetime="{{ post.date('c') }}">
            {{ post.date('M j, Y') }}
          </time>

          {% set raw_excerpt = function('get_post_field', 'post_excerpt', post.id) %}
          {% if not raw_excerpt %}
            {% set raw_excerpt = post.meta('_yoast_wpseo_metadesc') %}
          {% endif %}
          {% if raw_excerpt %}
            <p class="search-card__excerpt">{{ raw_excerpt }}</p>
          {% endif %}
        </article>
      {% else %}
        <div class="search-page__empty">
          <p class="search-page__empty-message">No results found for "{{ query }}".</p>
          <p class="search-page__empty-suggestion">Try a different search term or browse our <a href="{{ site.url }}/projects/">projects</a>.</p>
        </div>
      {% endfor %}
    </div>

    {% if posts.pagination and posts.pagination.pages|length > 1 %}
      <nav class="search-pagination" aria-label="Search results pagination">
        <ul class="search-pagination__list">
          {% if posts.pagination.prev %}
            <li>
              <a href="{{ posts.pagination.prev.link }}{{ active_post_type ? '&post_type=' ~ active_post_type : '' }}" class="search-pagination__link" aria-label="Previous page">&larr; Prev</a>
            </li>
          {% endif %}

          {% for page in posts.pagination.pages %}
            <li>
              {% if page.current %}
                <span class="search-pagination__link is-current" aria-current="page">{{ page.title }}</span>
              {% else %}
                <a href="{{ page.link }}{{ active_post_type ? '&post_type=' ~ active_post_type : '' }}" class="search-pagination__link">{{ page.title }}</a>
              {% endif %}
            </li>
          {% endfor %}

          {% if posts.pagination.next %}
            <li>
              <a href="{{ posts.pagination.next.link }}{{ active_post_type ? '&post_type=' ~ active_post_type : '' }}" class="search-pagination__link" aria-label="Next page">Next &rarr;</a>
            </li>
          {% endif %}
        </ul>
      </nav>
    {% endif %}
  </div>
{% endblock %}
