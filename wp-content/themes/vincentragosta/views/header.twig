<header class="header">
    <div class="header__container">
        <!-- Left: Mode Toggle -->
        <button
            class="header__mode-toggle"
            type="button"
            aria-label="Switch to light mode"
            aria-pressed="false"
        >
            <span class="header__mode-icon-wrapper">
                <span class="header__mode-icon header__mode-icon--sun" aria-hidden="true">
                    {{ icon('sun') | raw }}
                </span>
                <span class="header__mode-icon header__mode-icon--moon" aria-hidden="true">
                    {{ icon('moon') | raw }}
                </span>
            </span>
        </button>

        <!-- Center: Logo -->
        <p class="header__logo">
            <a href="{{ site.url }}" rel="home">{{ site.name }}</a>
        </p>

        <!-- Right: Search + Cart (shop only) + Hamburger -->
        <div class="header__actions">
            <form
                class="header__search"
                role="search"
                action="{{ site.url }}"
                method="get"
                aria-label="Site search"
            >
                <label for="header-search-input" class="screen-reader-text">Search</label>
                <input
                    id="header-search-input"
                    class="header__search-input"
                    type="search"
                    name="s"
                    placeholder="Search..."
                    aria-label="Search query"
                    tabindex="-1"
                />
                <button
                    class="header__search-toggle"
                    type="button"
                    aria-label="Open search"
                    aria-expanded="false"
                >
                    <span class="header__search-icon" aria-hidden="true">
                        {{ icon('search') | raw }}
                    </span>
                </button>
            </form>

            {{ function('do_action', 'vincentragosta_header_actions') }}

            <button
                class="header__menu-toggle"
                type="button"
                aria-label="Open menu"
                aria-expanded="false"
                aria-controls="nav-overlay"
            >
                <span class="header__menu-line" aria-hidden="true"></span>
                <span class="header__menu-line" aria-hidden="true"></span>
                <span class="header__menu-line" aria-hidden="true"></span>
            </button>
        </div>
    </div>

    {# Full-screen navigation overlay #}
    <nav
        id="nav-overlay"
        class="nav-overlay"
        aria-label="Primary navigation"
        hidden
    >
        <div class="nav-overlay__content">
            {{ function('wp_nav_menu', {
                theme_location: 'primary',
                container: false,
                menu_class: 'nav-overlay__list',
                depth: 1,
                fallback_cb: false
            }) }}
        </div>
    </nav>
</header>
