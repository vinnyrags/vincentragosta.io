{
  "$schema": "https://schemas.wp.org/wp/6.7/theme.json",
  "version": 2,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "layout": {
      "contentSize": "1280px",
      "wideSize": "1440px",
      "allowEditing": false
    },
    "color": {
      "defaultDuotone": false,
      "defaultGradients": false,
      "defaultPalette": false,
      "palette": [
        {
          "color": "#FFFFFF",
          "name": "Base",
          "slug": "base"
        },
        {
          "color": "#151515",
          "name": "Contrast",
          "slug": "contrast"
        },
        {
          "color": "#ceff00",
          "name": "Accent 1",
          "slug": "accent-1"
        },
        {
          "color": "#F6CFF4",
          "name": "Accent 2",
          "slug": "accent-2"
        },
        {
          "color": "#503AA8",
          "name": "Accent 3",
          "slug": "accent-3"
        },
        {
          "color": "#686868",
          "name": "Accent 4",
          "slug": "accent-4"
        },
        {
          "color": "#FBFAF3",
          "name": "Accent 5",
          "slug": "accent-5"
        },
        {
          "color": "color-mix(in srgb, currentColor 20%, transparent)",
          "name": "Accent 6",
          "slug": "accent-6"
        },
        {
          "color": "#afafb6",
          "name": "Grey 3",
          "slug": "grey-3"
        }
      ]
    },
    "spacing": {
      "spacingSizes": [
        {
          "name": "20",
          "slug": "20",
          "size": "0.5rem"
        },
        {
          "name": "30",
          "slug": "30",
          "size": "0.75rem"
        },
        {
          "name": "40",
          "slug": "40",
          "size": "1rem"
        },
        {
          "name": "50",
          "slug": "50",
          "size": "1.5rem"
        },
        {
          "name": "60",
          "slug": "60",
          "size": "2.25rem"
        },
        {
          "name": "70",
          "slug": "70",
          "size": "3rem"
        },
        {
          "name": "80",
          "slug": "80",
          "size": "10rem"
        }
      ]
    },
    "typography": {
      "writingMode": true,
      "defaultFontSizes": false,
      "fluid": true,
      "fontSizes": [
        {
          "fluid": false,
          "name": "Body Tiny",
          "size": "0.875rem",
          "slug": "body-tiny"
        },
        {
          "fluid": false,
          "name": "Body Small",
          "size": "1rem",
          "slug": "body-small"
        },
        {
          "fluid": {
            "max": "1.5rem",
            "min": "1rem"
          },
          "name": "Body Default",
          "size": "1.5rem",
          "slug": "body-default"
        },
        {
          "fluid": {
            "max": "2.4rem",
            "min": "2rem"
          },
          "name": "Body Large",
          "size": "2.4rem",
          "slug": "body-large"
        },
        {
          "fluid": {
            "max": "4.5rem",
            "min": "3.125rem"
          },
          "name": "Heading Medium",
          "size": "3.125rem",
          "slug": "heading-medium"
        },
        {
          "fluid": {
            "max": "5.5rem",
            "min": "4rem"
          },
          "name": "Heading Large",
          "size": "4rem",
          "slug": "heading-large"
        },
        {
          "fluid": {
            "max": "6.5rem",
            "min": "5rem"
          },
          "name": "Heading Extra Large",
          "size": "5rem",
          "slug": "heading-x-large"
        }
      ],
      "fontFamilies": [
        {
          "name": "Fira Code",
          "slug": "fira-code",
          "fontFamily": "'Fira Code', monospace"
        },
        {
          "fontFamily": "\"Reckless Neue\", Georgia, Times, serif",
          "name": "Reckless Neue",
          "slug": "reckless-neue",
          "fontFace": [
            {
              "fontFamily": "Reckless Neue",
              "fontWeight": "200",
              "fontStyle": "normal",
              "fontStretch": "normal",
              "src": [
                "file:./assets/fonts/reckless-neue/reckless-neue-thin.woff2",
                "file:./assets/fonts/reckless-neue/reckless-neue-thin.woff",
                "file:./assets/fonts/reckless-neue/reckless-neue-thin.eot"
              ]
            },
            {
              "fontFamily": "Reckless Neue",
              "fontWeight": "200",
              "fontStyle": "italic",
              "fontStretch": "normal",
              "src": [
                "file:./assets/fonts/reckless-neue/reckless-neue-thin-italic.woff2",
                "file:./assets/fonts/reckless-neue/reckless-neue-thin-italic.woff",
                "file:./assets/fonts/reckless-neue/reckless-neue-thin-italic.eot"
              ]
            },
            {
              "fontFamily": "Reckless Neue",
              "fontWeight": "300",
              "fontStyle": "normal",
              "fontStretch": "normal",
              "src": [
                "file:./assets/fonts/reckless-neue/reckless-neue-light.woff2",
                "file:./assets/fonts/reckless-neue/reckless-neue-light.woff"
              ]
            },
            {
              "fontFamily": "Reckless Neue",
              "fontWeight": "300",
              "fontStyle": "italic",
              "fontStretch": "normal",
              "src": [
                "file:./assets/fonts/reckless-neue/reckless-neue-light-italic.woff2",
                "file:./assets/fonts/reckless-neue/reckless-neue-light-italic.woff"
              ]
            }
          ]
        },
        {
          "fontFamily": "\"Roobert\", \"Helvetica Neue\", Arial, sans-serif",
          "name": "Roobert",
          "slug": "roobert",
          "fontFace": [
            {
              "fontFamily": "Roobert",
              "fontWeight": "300",
              "fontStyle": "normal",
              "fontStretch": "normal",
              "src": [
                "file:./assets/fonts/roobert/roobert-light.otf"
              ]
            },
            {
              "fontFamily": "Roobert",
              "fontWeight": "500",
              "fontStyle": "normal",
              "fontStretch": "normal",
              "src": [
                "file:./assets/fonts/roobert/roobert-medium.otf"
              ]
            },
            {
              "fontFamily": "Roobert",
              "fontWeight": "500",
              "fontStyle": "italic",
              "fontStretch": "normal",
              "src": [
                "file:./assets/fonts/roobert/roobert-medium-italic.otf"
              ]
            }
          ]
        }
      ]
    }
  },
  "styles": {
    "spacing": {
      "blockGap": "var:preset|spacing|80",
      "padding": {
        "top": "var:preset|spacing|50",
        "right": "var:preset|spacing|40",
        "bottom": "var:preset|spacing|50",
        "left": "var:preset|spacing|40"
      }
    },
    "color": {
      "background": "var:preset|color|contrast",
      "text": "var:preset|color|base"
    },
    "typography": {
      "fontFamily": "var:preset|font-family|roobert",
      "fontSize": "var:preset|font-size|body-default",
      "fontWeight": "300",
      "letterSpacing": "-0.3px"
    },
    "blocks": {
      "core/avatar": {
        "border": {
          "radius": "100px"
        }
      },
      "core/button": {
        "typography": {
          "fontSize": "var:preset|font-size|body-small",
          "fontWeight": "400",
          "textTransform": "uppercase"
        },
        "spacing": {
          "padding": {
            "right": "var:preset|spacing|50",
            "bottom": "var:preset|spacing|40",
            "left": "var:preset|spacing|50",
            "top": "var:preset|spacing|40"
          }
        }
      },
      "core/columns": {
        "spacing": {
          "blockGap": "var:preset|spacing|50"
        }
      },
      "core/buttons": {
        "spacing": {
          "blockGap": "16px"
        }
      },
      "core/code": {
        "typography": {
          "fontFamily": "var:preset|font-family|fira-code",
          "fontWeight": "400"
        },
        "color": {
          "background": "var:preset|color|accent-5",
          "text": "var:preset|color|contrast"
        },
        "spacing": {
          "padding": {
            "right": "var:preset|spacing|40",
            "bottom": "var:preset|spacing|40",
            "left": "var:preset|spacing|40",
            "top": "var:preset|spacing|40"
          }
        }
      },
      "core/comment-author-name": {
        "color": {
          "text": "var:preset|color|accent-4"
        },
        "elements": {
          "link": {
            "color": {
              "text": "var:preset|color|accent-4"
            },
            "typography": {
              "textDecoration": "none"
            },
            ":hover": {
              "typography": {
                "textDecoration": "underline"
              }
            }
          }
        },
        "typography": {
          "fontSize": "var:preset|font-size|body-default"
        },
        "spacing": {
          "margin": {
            "top": "5px",
            "bottom": "0px"
          }
        }
      },
      "core/comment-content": {
        "typography": {
          "fontSize": "var:preset|font-size|body-default"
        },
        "spacing": {
          "margin": {
            "top": "var:preset|spacing|20",
            "bottom": "var:preset|spacing|20"
          }
        }
      },
      "core/comment-date": {
        "typography": {
          "fontSize": "var:preset|font-size|body-small"
        },
        "color": {
          "text": "var:preset|color|contrast"
        },
        "elements": {
          "link": {
            "color": {
              "text": "var:preset|color|contrast"
            }
          }
        }
      },
      "core/comment-edit-link": {
        "elements": {
          "link": {
            "color": {
              "text": "var:preset|color|contrast"
            }
          }
        },
        "typography": {
          "fontSize": "var:preset|font-size|body-small"
        }
      },
      "core/comment-reply-link": {
        "elements": {
          "link": {
            "color": {
              "text": "var:preset|color|contrast"
            }
          }
        },
        "typography": {
          "fontSize": "var:preset|font-size|body-small"
        }
      },
      "core/post-comments-form": {
        "css": "& textarea, input:not([type=submit]){border-radius:.25rem; border-color: var(--wp--preset--color--accent-6) !important;} & input[type=checkbox]{margin:0 .2rem 0 0 !important;} & label {font-size: var(--wp--preset--font-size--small); }",
        "typography": {
          "fontSize": "var:preset|font-size|body-default"
        },
        "spacing": {
          "padding": {
            "top": "var:preset|spacing|40",
            "bottom": "var:preset|spacing|40"
          }
        }
      },
      "core/comments-pagination": {
        "typography": {
          "fontSize": "var:preset|font-size|body-default"
        },
        "spacing": {
          "margin": {
            "top": "var:preset|spacing|40",
            "bottom": "var:preset|spacing|40"
          }
        }
      },
      "core/comments-pagination-next": {
        "typography": {
          "fontSize": "var:preset|font-size|body-default"
        }
      },
      "core/comments-pagination-numbers": {
        "typography": {
          "fontSize": "var:preset|font-size|body-default"
        }
      },
      "core/comments-pagination-previous": {
        "typography": {
          "fontSize": "var:preset|font-size|body-default"
        }
      },
      "core/post-date": {
        "color": {
          "text": "var:preset|color|accent-4"
        },
        "elements": {
          "link": {
            "color": {
              "text": "var:preset|color|accent-4"
            },
            ":hover": {
              "typography": {
                "textDecoration": "underline"
              }
            },
            "typography": {
              "textDecoration": "none"
            }
          }
        },
        "typography": {
          "fontSize": "var:preset|font-size|body-small"
        }
      },
      "core/post-navigation-link": {
        "typography": {
          "fontSize": "var:preset|font-size|body-default"
        }
      },
      "core/post-terms": {
        "css": "& a { white-space: nowrap; }",
        "typography": {
          "fontSize": "var:preset|font-size|body-small",
          "fontWeight": "600"
        }
      },
      "core/post-title": {
        "elements": {
          "link": {
            ":hover": {
              "typography": {
                "textDecoration": "underline"
              }
            },
            "typography": {
              "textDecoration": "none"
            }
          }
        }
      },
      "core/quote": {
        "border": {
          "style": "solid",
          "width": "0 0 0 2px",
          "color": "currentColor"
        },
        "spacing": {
          "blockGap": "var:preset|spacing|20",
          "margin": {
            "left": "0",
            "right": "0"
          },
          "padding": {
            "top": "var:preset|spacing|20",
            "right": "var:preset|spacing|40",
            "bottom": "var:preset|spacing|20",
            "left": "var:preset|spacing|40"
          }
        },
        "typography": {
          "fontSize": "var:preset|font-size|heading-medium",
          "fontWeight": "300"
        },
        "elements": {
          "cite": {
            "typography": {
              "fontSize": "var:preset|font-size|body-small",
              "fontStyle": "normal",
              "fontWeight": "300"
            },
            "css": "& sub { font-size: 0.65em }"
          }
        },
        "css": "&.has-text-align-right { border-width: 0 2px 0 0; } &.has-text-align-center { border-width: 0;border-inline: 0; padding-inline: 0; }",
        "variations": {
          "plain": {
            "border": {
              "color": "transparent",
              "style": "none",
              "width": "0",
              "radius": "0"
            },
            "spacing": {
              "padding": {
                "top": "0",
                "right": "0",
                "bottom": "0",
                "left": "0"
              }
            }
          }
        }
      },
      "core/pullquote": {
        "typography": {
          "fontSize": "var:preset|font-size|heading-medium",
          "fontWeight": "300",
          "lineHeight": "1.2"
        },
        "elements": {
          "cite": {
            "typography": {
              "fontSize": "var:preset|font-size|body-small",
              "fontStyle": "normal"
            }
          }
        },
        "spacing": {
          "padding": {
            "bottom": "var:preset|spacing|20",
            "top": "var:preset|spacing|20"
          }
        },
        "css": "& p:last-of-type {margin-bottom: var(--wp--preset--spacing--regular);}"
      },
      "core/query-pagination": {
        "typography": {
          "fontSize": "var:preset|font-size|body-default",
          "fontWeight": "500"
        }
      },
      "core/search": {
        "css": "& .wp-block-search__input{border-radius:3.125rem;padding-left:1.5625rem;padding-right:1.5625rem;border-color:var(--wp--preset--color--accent-6);}",
        "typography": {
          "fontSize": "var:preset|font-size|body-default",
          "lineHeight": "1.6"
        },
        "elements": {
          "button": {
            "border": {
              "radius": "3.125rem"
            },
            "spacing": {
              "margin": {
                "left": "1.125rem"
              }
            },
            ":hover": {
              "border": {
                "color": "transparent"
              }
            }
          }
        }
      },
      "core/separator": {
        "border": {
          "color": "currentColor",
          "style": "solid",
          "width": "0 0 1px 0"
        },
        "color": {
          "text": "var:preset|color|accent-6"
        },
        "variations": {
          "wide": {
            "css": " &:not(.alignfull){max-width: var(--wp--style--global--wide-size) !important;}"
          }
        }
      },
      "core/site-tagline": {
        "typography": {
          "fontSize": "var:preset|font-size|body-default"
        }
      },
      "core/site-title": {
        "typography": {
          "fontWeight": "700",
          "letterSpacing": "-.5px"
        },
        "elements": {
          "link": {
            "typography": {
              "textDecoration": "none"
            },
            ":hover": {
              "typography": {
                "textDecoration": "underline"
              }
            }
          }
        }
      },
      "core/term-description": {
        "typography": {
          "fontSize": "var:preset|font-size|body-default"
        }
      },
      "core/navigation": {
        "typography": {
          "fontSize": "var:preset|font-size|body-default"
        },
        "elements": {
          "link": {
            ":hover": {
              "typography": {
                "textDecoration": "underline"
              }
            },
            "typography": {
              "textDecoration": "none"
            }
          }
        }
      },
      "core/list": {
        "css": "& li{margin-top: 0.5rem;}"
      }
    },
    "elements": {
      "button": {
        "color": {
          "background": "var:preset|color|base",
          "text": "var:preset|color|contrast"
        },
        ":focus": {
          "outline": {
            "color": "var:preset|color|accent-4",
            "offset": "2px"
          }
        },
        ":hover": {
          "color": {
            "background": "var:preset|color|accent-1",
            "text": "var:preset|color|contrast"
          },
          "border": {
            "color": "transparent"
          }
        },
        "typography": {
          "fontSize": "var:preset|font-size|body-small",
          "fontWeight": "500",
          "textTransform": "uppercase"
        },
        "spacing": {
          "padding": {
            "right": "var:preset|spacing|20",
            "bottom": "var:preset|spacing|30",
            "left": "var:preset|spacing|20",
            "top": "var:preset|spacing|30"
          }
        }
      },
      "caption": {
        "typography": {
          "fontSize": "var:preset|font-size|body-small",
          "lineHeight": "1.4"
        }
      },
      "heading": {
        "typography": {
          "fontFamily": "var:preset|font-family|reckless-neue",
          "fontWeight": "200",
          "lineHeight": "1.125",
          "fontSize": "var:preset|font-size|body-large"
        },
        "color": {
          "text": "var:preset|color|base"
        }
      },
      "link": {
        "color": {
          "text": "currentColor"
        },
        ":hover": {
          "typography": {
            "textDecoration": "none"
          }
        }
      }
    }
  },
  "templateParts": [
    {
      "area": "header",
      "name": "header",
      "title": "Header"
    },
    {
      "area": "header",
      "name": "vertical-header",
      "title": "Vertical Header"
    },
    {
      "area": "header",
      "name": "header-large-title",
      "title": "Header with large title"
    },
    {
      "area": "footer",
      "name": "footer",
      "title": "Footer"
    },
    {
      "area": "footer",
      "name": "footer-columns",
      "title": "Footer Columns"
    },
    {
      "area": "footer",
      "name": "footer-newsletter",
      "title": "Footer Newsletter"
    },
    {
      "area": "uncategorized",
      "name": "sidebar",
      "title": "Sidebar"
    }
  ],
  "customTemplates": [
    {
      "name": "page-no-title",
      "postTypes": [
        "page"
      ],
      "title": "Page No Title"
    }
  ]
}