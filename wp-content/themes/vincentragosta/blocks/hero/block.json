{
  "apiVersion": 3,
  "name": "vincentragosta/hero",
  "title": "Hero",
  "category": "design",
  "icon": "cover-image",
  "description": "Native hero block with title, subtitle, buttons, and SVG.",
  "keywords": ["hero", "native", "banner", "svg", "buttons"],
  "attributes": {
    "title": {
      "type": "string"
    },
    "subtitle": {
      "type": "string"
    },
    "svgAsset": {
      "type": "string",
      "default": ""
    },
    "align": {
      "type": "string",
      "default": ""
    }
  },
  "supports": {
    "html": false,
    "align": ["wide", "full"],
    "anchor": true,
    "innerBlocks": true
  },
  "usesContext": ["postId", "queryId"],
  "providesContext": {
    "parentBlock": "vincentragosta/hero"
  },
  "textdomain": "vincentragosta",
  "editorScript": "file:./build/index.js",
  "editorStyle": "file:./build/index.css",
  "style": "file:./build/style-index.css",
  "render": "file:./render.php"
}