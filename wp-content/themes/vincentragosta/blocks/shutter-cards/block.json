{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "vincentragosta/shutter-cards",
  "title": "Shutter Card",
  "category": "design",
  "icon": "format-aside",
  "description": "A single, stylized card with a title, subtitle, and description.",
  "keywords": ["card", "content", "info", "shutter"],
  "attributes": {
    "title": {
      "type": "string"
    },
    "subtitle": {
      "type": "string"
    },
    "description": {
      "type": "string"
    }
  },
  "supports": {
    "html": false,
    "align": ["wide", "full"],
    "spacing": {
      "padding": true,
      "margin": true
    }
  },
  "textdomain": "vincentragosta",
  "editorScript": "file:./build/index.js",
  "editorStyle": "file:./build/editor.css",
  "style": "file:./build/style-index.css",
  "render": "file:./render.php"
}