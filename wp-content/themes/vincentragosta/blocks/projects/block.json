    "align": {
      "type": "string",
      "default": "wide"
    }
  },
  "supports": {
    "html": false,
    "align": ["wide", "full"],
    "spacing": {
      "margin": true,
      "padding": true
    }
  },
  "textdomain": "vincentragosta",
  "editorScript": "file:./build/index.js",
  "style": "file:./build/style-index.css",
  "render": "file:./render.php"
}