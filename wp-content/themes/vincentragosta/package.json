{
  "name": "vincentragosta",
  "version": "1.0.0",
  "description": "[![Build Status](https://travis-ci.com/timber/starter-theme.svg?branch=master)](https://travis-ci.com/github/timber/starter-theme) [![Packagist Version](https://img.shields.io/packagist/v/upstatement/timber-starter-theme?include_prereleases)](https://packagist.org/packages/upstatement/timber-starter-theme)",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "build-assets": "wp-scripts build assets/src/js/main.js assets/src/js/frontend.js --output-path=assets/src/build/js",
    "compile-theme-css": "sass assets/src/scss/main.scss style.css --no-source-map --style=expanded",
    "build-blocks": "wp-scripts build blocks/index.js blocks/index-view.js --output-path=blocks/build",
    "build": "npm run build-assets && npm run build-blocks && npm run compile-theme-css",
    "start-assets": "wp-scripts start assets/src/js/main.js assets/src/js/frontend.js --output-path=assets/src/build/js",
    "watch-theme-css": "sass assets/src/scss/main.scss style.css --no-source-map --style=expanded --watch",
    "start-blocks": "wp-scripts start blocks/index.js blocks/index-view.js --output-path=blocks/build",
    "start": "npm-run-all --parallel start-assets start-blocks watch-theme-css"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@wordpress/icons": "^10.21.0",
    "@wordpress/scripts": "^30.14.1",
    "autoprefixer": "^10.4.21",
    "npm-run-all": "^4.1.5",
    "esbuild": "^0.25.1",
    "postcss": "^8.5.3",
    "sass": "^1.86.0"
  }
}