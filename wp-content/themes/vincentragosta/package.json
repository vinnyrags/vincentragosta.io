{
  "name": "vincentragosta",
  "version": "1.0.0",
  "description": "[![Build Status](https://travis-ci.com/timber/starter-theme.svg?branch=master)](https://travis-ci.com/github/timber/starter-theme) [![Packagist Version](https://img.shields.io/packagist/v/upstatement/timber-starter-theme?include_prereleases)](https://packagist.org/packages/upstatement/timber-starter-theme)",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "build-assets": "wp-scripts build assets/src/js/custom-formats.js assets/src/js/custom-paragraph-styles.js --output-path=assets/src/build/js",
    "build-block:hero": "wp-scripts build blocks/hero/index.js --output-path=blocks/hero/build",
    "build-blocks": "npm run build-block:hero",
    "build": "npm run build-assets && npm run build-blocks",
    "start-assets": "wp-scripts start assets/src/js/custom-formats.js assets/src/js/custom-paragraph-styles.js --output-path=assets/src/build/js",
    "start-block:hero": "wp-scripts start blocks/hero/index.js",
    "start-blocks": "npm-run-all --parallel start-block:hero",
    "start": "npm-run-all --parallel start-assets start-blocks"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@wordpress/icons": "^10.21.0",
    "@wordpress/scripts": "^30.14.1",
    "autoprefixer": "^10.4.21",
    "npm-run-all": "^4.1.5",
    "esbuild": "^0.25.1",
    "postcss": "^8.5.3",
    "sass": "^1.86.0"
  }
}
