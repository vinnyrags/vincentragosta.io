{
  "name": "child-theme",
  "version": "1.0.0",
  "description": "[![Build Status](https://travis-ci.com/timber/starter-theme.svg?branch=master)](https://travis-ci.com/github/timber/starter-theme) [![Packagist Version](https://img.shields.io/packagist/v/upstatement/timber-starter-theme?include_prereleases)](https://packagist.org/packages/upstatement/timber-starter-theme)",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "build-assets": "wp-scripts build assets/src/js/main.js assets/src/js/frontend.js --output-path=dist/js",
    "build-parent": "npm --prefix ../parent-theme run build",
    "compile-providers": "node scripts/compile-providers.js",
    "watch-providers": "node scripts/compile-providers.js --watch",
    "build-blocks": "wp-scripts build blocks/index.js --output-path=dist/blocks",
    "build-block-views": "node scripts/build-block-views.js",
    "watch-block-views": "node scripts/build-block-views.js --watch",
    "build": "npm run build-parent && npm run build-assets && npm run build-blocks && npm run build-block-views && npm run compile-providers",
    "start-assets": "wp-scripts start assets/src/js/main.js assets/src/js/frontend.js --output-path=dist/js",
    "watch-parent": "npm --prefix ../parent-theme run start",
    "start-blocks": "wp-scripts start blocks/index.js --output-path=dist/blocks",
    "start": "npm-run-all --parallel start-assets start-blocks watch-block-views watch-parent watch-providers"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@wordpress/icons": "^10.21.0",
    "@wordpress/scripts": "^30.14.1",
    "autoprefixer": "^10.4.21",
    "npm-run-all": "^4.1.5",
    "esbuild": "^0.25.1",
    "postcss": "^8.5.3",
    "sass": "^1.86.0"
  }
}