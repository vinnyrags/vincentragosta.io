{
  "name": "child-theme",
  "version": "1.0.0",
  "description": "[![Build Status](https://travis-ci.com/timber/starter-theme.svg?branch=master)](https://travis-ci.com/github/timber/starter-theme) [![Packagist Version](https://img.shields.io/packagist/v/upstatement/timber-starter-theme?include_prereleases)](https://packagist.org/packages/upstatement/timber-starter-theme)",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "build-parent": "npm --prefix ../parent-theme run build",
    "build-providers": "node ../parent-theme/scripts/build-providers.js",
    "watch-providers": "node ../parent-theme/scripts/build-providers.js --watch",
    "build": "npm run build-parent && npm run build-providers",
    "watch-parent": "npm --prefix ../parent-theme run start",
    "start": "npm-run-all --parallel watch-parent watch-providers",
    "prepare": "cd ../../.. && husky wp-content/themes/child-theme/.husky",
    "test:php": "composer test",
    "test:php:parent": "composer --working-dir=../parent-theme test",
    "test:php:all": "npm run test:php && npm run test:php:parent"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "esbuild": "^0.25.1",
    "husky": "^9.1.7",
    "npm-run-all": "^4.1.5",
    "sass": "^1.86.0"
  }
}
