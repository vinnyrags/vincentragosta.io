<footer class="footer">
    <div class="footer__inner">
        {# Contact Section #}
        <section class="footer__contact" aria-labelledby="footer-contact-heading">
            <div class="footer__contact-heading">
                <h2 class="footer__heading" id="footer-contact-heading">Let's start a <strong>conversation</strong></h2>
                <a href="mailto:hello@vincentragosta.io" class="wp-element-button button has-icon">
                    Get in touch today
                    <span class="button__icon arrow" aria-hidden="true">
                        {{ icon('arrow') | raw }}
                    </span>
                </a>
            </div>
            {% if options.footer_description %}
                <div class="footer__contact-body">
                    <div class="footer__description">{{ options.footer_description | raw }}</div>
                </div>
            {% endif %}
        </section>

        <hr class="footer__separator" aria-hidden="true">

        {# Bar: Copyright, Nav, Social #}
        <div class="footer__bar">
            <div class="footer__meta">
                <p class="footer__copyright">&copy; {{ "now"|date('Y') }} Vincent Ragosta</p>
                <nav class="footer__nav" aria-label="Footer navigation">
                    {{ function('wp_nav_menu', {
                        theme_location: 'footer',
                        container: false,
                        menu_class: 'footer__nav-list',
                        depth: 1,
                        fallback_cb: false
                    }) }}
                </nav>
            </div>

            {% if options.social_icons %}
                <nav class="footer__social-nav" aria-label="Social media links">
                    <ul role="list">
                        {% for social in options.social_icons %}
                            <li>
                                <a href="{{ social.url }}" class="footer__social-link" aria-label="{{ social.platform }} (opens in new tab)" target="_blank" rel="noopener noreferrer">
                                    {{ icon(social.icon) | raw }}
                                </a>
                            </li>
                        {% endfor %}
                    </ul>
                </nav>
            {% endif %}
        </div>
    </div>
</footer>
