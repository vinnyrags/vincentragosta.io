{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "layout": {
      "contentSize": "1440px",
      "wideSize": "1600px"
    },
    "custom": {
      "layout": {
        "narrow": "1200px",
        "wide": "1600px"
      },
      "borderRadius": "10px",
      "color": {
        "error": "#e74c3c",
        "accent1Dark": "#3d8500"
      }
    },
    "spacing": {
      "spacingSizes": [
        {
          "name": "20",
          "slug": "20",
          "size": "0.5rem"
        },
        {
          "name": "30",
          "slug": "30",
          "size": "1rem"
        },
        {
          "name": "40",
          "slug": "40",
          "size": "1.5rem"
        },
        {
          "name": "50",
          "slug": "50",
          "size": "2.5rem"
        },
        {
          "name": "60",
          "slug": "60",
          "size": "4rem"
        },
        {
          "name": "65",
          "slug": "65",
          "size": "clamp(4rem, 15vw, 7rem)"
        },
        {
          "name": "70",
          "slug": "70",
          "size": "clamp(6rem, 15vw, 20rem)"
        }
      ]
    },
    "color": {
      "palette": [
        {
          "color": "#FFFFFF",
          "name": "Base",
          "slug": "base"
        },
        {
          "color": "#151515",
          "name": "Contrast",
          "slug": "contrast"
        },
        {
          "color": "#ceff00",
          "name": "Accent 1",
          "slug": "accent-1"
        },
        {
          "color": "#1c1c1f",
          "name": "Grey 1",
          "slug": "grey-1"
        },
        {
          "color": "#313135",
          "name": "Grey 2",
          "slug": "grey-2"
        },
        {
          "color": "#afafb6",
          "name": "Grey 3",
          "slug": "grey-3"
        },
        {
          "color": "#494950",
          "name": "Grey 4",
          "slug": "grey-4"
        },
        {
          "color": "#95959d",
          "name": "Grey 5",
          "slug": "grey-5"
        },
        {
          "color": "#ff3333",
          "name": "Nous Red",
          "slug": "nous-red"
        }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "name": "Fira Code",
          "slug": "fira-code",
          "fontFamily": "'Fira Code', monospace"
        },
        {
          "fontFamily": "\"Reckless Neue\", Georgia, Times, serif",
          "name": "Reckless Neue",
          "slug": "reckless-neue",
          "fontFace": [
            {
              "fontFamily": "Reckless Neue",
              "fontWeight": "400",
              "fontStyle": "normal",
              "fontStretch": "normal",
              "src": [
                "file:./src/Providers/Theme/assets/fonts/reckless-neue/reckless-neue-thin.woff2",
                "file:./src/Providers/Theme/assets/fonts/reckless-neue/reckless-neue-thin.woff"
              ]
            },
            {
              "fontFamily": "Reckless Neue",
              "fontWeight": "400",
              "fontStyle": "italic",
              "fontStretch": "normal",
              "src": [
                "file:./src/Providers/Theme/assets/fonts/reckless-neue/reckless-neue-thin-italic.woff2",
                "file:./src/Providers/Theme/assets/fonts/reckless-neue/reckless-neue-thin-italic.woff"
              ]
            },
            {
              "fontFamily": "Reckless Neue",
              "fontWeight": "700",
              "fontStyle": "normal",
              "fontStretch": "normal",
              "src": [
                "file:./src/Providers/Theme/assets/fonts/reckless-neue/reckless-neue-light.woff2",
                "file:./src/Providers/Theme/assets/fonts/reckless-neue/reckless-neue-light.woff"
              ]
            },
            {
              "fontFamily": "Reckless Neue",
              "fontWeight": "700",
              "fontStyle": "italic",
              "fontStretch": "normal",
              "src": [
                "file:./src/Providers/Theme/assets/fonts/reckless-neue/reckless-neue-light-italic.woff2",
                "file:./src/Providers/Theme/assets/fonts/reckless-neue/reckless-neue-light-italic.woff"
              ]
            }
          ]
        },
        {
          "fontFamily": "\"Roobert\", \"Helvetica Neue\", Arial, sans-serif",
          "name": "Roobert",
          "slug": "roobert",
          "fontFace": [
            {
              "fontFamily": "Roobert",
              "fontWeight": "400",
              "fontStyle": "normal",
              "fontStretch": "normal",
              "src": [
                "file:./src/Providers/Theme/assets/fonts/roobert/roobert-light.otf"
              ]
            },
            {
              "fontFamily": "Roobert",
              "fontWeight": "400",
              "fontStyle": "italic",
              "fontStretch": "normal",
              "src": [
                "file:./src/Providers/Theme/assets/fonts/roobert/roobert-light-italic.otf"
              ]
            },
            {
              "fontFamily": "Roobert",
              "fontWeight": "700",
              "fontStyle": "normal",
              "fontStretch": "normal",
              "src": [
                "file:./src/Providers/Theme/assets/fonts/roobert/roobert-medium.otf"
              ]
            },
            {
              "fontFamily": "Roobert",
              "fontWeight": "700",
              "fontStyle": "italic",
              "fontStretch": "normal",
              "src": [
                "file:./src/Providers/Theme/assets/fonts/roobert/roobert-medium-italic.otf"
              ]
            }
          ]
        }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var:preset|color|contrast",
      "text": "var:preset|color|base"
    },
    "typography": {
      "fontFamily": "var:preset|font-family|roobert"
    },
    "blocks": {
      "core/button": {
        "typography": {
          "fontWeight": "700"
        }
      },
      "core/separator": {
        "color": {
          "text": "var:preset|color|grey-2"
        }
      }
    },
    "elements": {
      "button": {
        "border": {
          "radius": "9999px"
        },
        "color": {
          "background": "var:preset|color|base",
          "text": "var:preset|color|contrast"
        },
        ":focus": {
          "outline": {
            "color": "var:preset|color|accent-1"
          }
        },
        ":hover": {
          "border": {
            "color": "transparent"
          },
          "color": {
            "background": "var:preset|color|accent-1",
            "text": "var:preset|color|contrast"
          }
        },
        "typography": {
          "fontWeight": "700",
          "textTransform": "uppercase"
        }
      },
      "heading": {
        "typography": {
          "fontFamily": "var:preset|font-family|reckless-neue",
          "fontWeight": "400"
        },
        "color": {
          "text": "var:preset|color|base"
        }
      },
      "link": {
        "color": {
          "text": "currentColor"
        },
        ":hover": {
          "color": {
            "text": "var:preset|color|accent-1"
          }
        }
      }
    }
  }
}
