<div class="projects-grid">
    {% for project in projects %}
        {% set project_category = project.terms('project_category')|first %}
        <div class="project-card">
            <a href="{{ project.link }}" class="project-card__image-link" aria-label="View project: {{ project.title }}">
                {% if project.thumbnail %}
                    <img src="{{ project.thumbnail.src }}" alt="{{ project.thumbnail.alt|e }}">
                {% else %}
                    <div class="project-card__no-image" aria-hidden="true"></div>
                {% endif %}
            </a>
            <div class="project-card__content">
                {% if project_category %}
                    <span class="project-card__category">{{ project_category.name }}</span>
                {% endif %}
                <h3 class="project-card__title">
                    <a href="{{ project.link }}">
                        {{ project.title }}
                    </a>
                </h3>
            </div>
        </div>
    {% else %}
        <p>No projects to display.</p>
    {% endfor %}
</div>