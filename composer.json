{
  "name": "vinnyrags/vincentragostaio",
  "description": "Personal website",
  "type": "project",
  "repositories": [
    {
      "type": "composer",
      "url": "https://packages.vincentragosta.io"
    },
    {
      "type": "composer",
      "url": "https://wpackagist.org"
    },
    {
      "type": "composer",
      "url": "https://connect.advancedcustomfields.com"
    }
  ],
  "require": {
    "php": ">=8.4",
    "composer/installers": "^1.12 || ^2.0",
    "johnpbloch/wordpress": "^6.5",
    "wpengine/advanced-custom-fields-pro": "^6.0",
    "ext-dom": "*",
    "wpackagist-plugin/wpforms-lite": "^1.9",
    "wpackagist-plugin/wordpress-seo": "^24.0",
    "wpackagist-plugin/relevanssi": "^4.26",
    "vincentragosta/mythus": "dev-main",
    "vincentragosta/ix": "dev-main",
    "wpackagist-plugin/instagram-feed": "^6.10",
    "wpackagist-plugin/wordpress-importer": "^0.9",
    "wpackagist-plugin/wp-graphql": "^2.0",
    "wpackagist-plugin/wpgraphql-acf": "^2.5"
  },
  "extra": {
    "wordpress-install-dir": "wp",
    "installer-paths": {
      "wp-content/mu-plugins/{$name}/": [
        "type:wordpress-muplugin"
      ],
      "wp-content/plugins/{$name}/": [
        "type:wordpress-plugin"
      ],
      "wp-content/themes/{$name}/": [
        "type:wordpress-theme"
      ]
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "composer/installers": true,
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "johnpbloch/wordpress-core-installer": true
    }
  }
}
